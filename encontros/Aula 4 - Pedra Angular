{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyOJrZm6GYBlR/JF7ZmCkHEE"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["# ==============================================================================\n","# 👨‍🏫 AULA PRÁTICA: Tratamento de Outliers em Detecção de Fraude\n","# ==============================================================================\n","# Autor: Seu Consultor de Data Science\n","# Tópico: Pipeline Robusto com Imblearn, IQR vs Isolation Forest\n","# ==============================================================================\n","\n","# 1. INSTALAÇÃO E IMPORTAÇÃO DE BIBLIOTECAS\n","# ------------------------------------------------------------------------------\n","# Em um ambiente local, você precisaria instalar: pip install imbalanced-learn\n","import numpy as np\n","import pandas as pd\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","\n","# Scikit-Learn e Imblearn\n","from sklearn.model_selection import train_test_split, StratifiedKFold\n","from sklearn.preprocessing import StandardScaler\n","from sklearn.linear_model import LogisticRegression\n","from sklearn.metrics import precision_recall_curve, auc, classification_report\n","from sklearn.ensemble import IsolationForest\n","from sklearn.base import BaseEstimator, TransformerMixin\n","\n","#!IMPORTANTE!: Usamos o Pipeline do imblearn, não do sklearn.\n","# O do sklearn não permite remover linhas (amostras) durante o fit.\n","from imblearn.pipeline import Pipeline as ImbPipeline\n","from imblearn import FunctionSampler"],"metadata":{"id":"eF4qOWNfqNwg","executionInfo":{"status":"ok","timestamp":1769453744703,"user_tz":180,"elapsed":5,"user":{"displayName":"David Farias","userId":"01485825138402810596"}}},"execution_count":19,"outputs":[]},{"cell_type":"code","source":["# Configuração visual estilo \"Canal\"\n","sns.set_style(\"whitegrid\")\n","plt.rcParams['figure.figsize'] = (12, 6)\n","plt.rcParams['font.size'] = 12"],"metadata":{"id":"SUr4lzYJqZ9Z","executionInfo":{"status":"ok","timestamp":1769453759220,"user_tz":180,"elapsed":5,"user":{"displayName":"David Farias","userId":"01485825138402810596"}}},"execution_count":20,"outputs":[]},{"cell_type":"code","source":["# ==============================================================================\n","# 2. GERADOR DE DADOS SINTÉTICOS (Simulando o Kaggle Credit Card)\n","# ==============================================================================\n","# Como o dataset original é pesado, vamos criar um que imita suas propriedades:\n","# - Desbalanceamento extremo (0.2% fraude)\n","# - Features V14, V12, V10 onde a fraude é um \"Outlier\" estatístico\n","# ==============================================================================\n","\n","def gerar_dados_fraude_simulados(n_samples=50000, fraud_ratio=0.005):\n","    np.random.seed(42)\n","    n_fraud = int(n_samples * fraud_ratio)\n","    n_legit = n_samples - n_fraud\n","\n","    # Gerar transações legítimas (distribuição normal centrada em 0)\n","    X_legit = np.random.normal(loc=0, scale=1, size=(n_legit, 3)) # V14, V12, V10\n","\n","    # Gerar fraudes (distribuição deslocada para as caudas - outliers!)\n","    # No dataset Kaggle, V14 tem correlação negativa forte (fraudes são valores muito baixos)\n","    X_fraud = np.random.normal(loc=-6, scale=1.5, size=(n_fraud, 3))\n","\n","    # Juntar\n","    X = np.vstack([X_legit, X_fraud])\n","    y = np.hstack([np.zeros(n_legit), np.ones(n_fraud)])\n","\n","    # Criar DataFrame\n","    cols = ['V14', 'V12', 'V10']\n","    df = pd.DataFrame(X, columns=cols)\n","    df['Class'] = y\n","\n","    print(f\"Dados Gerados: {n_samples} transações.\")\n","    print(f\"Legítimas: {n_legit} | Fraudes: {n_fraud} ({fraud_ratio*100}%)\")\n","    return df"],"metadata":{"id":"llJ97SNrqZ4-","executionInfo":{"status":"ok","timestamp":1769453776856,"user_tz":180,"elapsed":4,"user":{"displayName":"David Farias","userId":"01485825138402810596"}}},"execution_count":21,"outputs":[]},{"cell_type":"code","source":["# Gerando o dataset\n","df = gerar_dados_fraude_simulados()\n","X = df.drop('Class', axis=1)\n","y = df['Class']\n","\n","# Separar Treino e Teste (Obrigatório antes de qualquer limpeza!)\n","X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, stratify=y, random_state=42)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"7feoS9RUqh-K","executionInfo":{"status":"ok","timestamp":1769453791775,"user_tz":180,"elapsed":157,"user":{"displayName":"David Farias","userId":"01485825138402810596"}},"outputId":"d81185cf-25b3-4c04-bbe2-25bac5edd2f4"},"execution_count":22,"outputs":[{"output_type":"stream","name":"stdout","text":["Dados Gerados: 50000 transações.\n","Legítimas: 49750 | Fraudes: 250 (0.5%)\n"]}]},{"cell_type":"code","source":["# ==============================================================================\n","# 3. ANÁLISE EXPLORATÓRIA (O Motivo do Paradoxo)\n","# ==============================================================================\n","# Vamos visualizar por que métodos simples falham.\n","# Plotamos o Boxplot da feature V14.\n","# ------------------------------------------------------------------------------\n","\n","def plot_paradoxo_outlier(df):\n","    plt.figure(figsize=(14, 6))\n","\n","    # Boxplot Global (como um iniciante veria)\n","    plt.subplot(1, 2, 1)\n","    sns.boxplot(x=df['V14'], color='skyblue')\n","    plt.title('Visão Iniciante: V14 Global (Tudo misturado)')\n","    plt.xlabel('V14 Value')\n","\n","    # Boxplot por Classe (A realidade)\n","    plt.subplot(1, 2, 2)\n","    sns.boxplot(x='Class', y='V14', hue='Class', data=df, palette={0.0: \"skyblue\", 1.0: \"red\"}, legend=False)\n","    plt.title('Visão Expert: V14 Separado por Classe')\n","    plt.xlabel('Classe (0=Legítima, 1=Fraude)')\n","\n","    plt.tight_layout()\n","    plt.show()\n","\n","print(\"\\n>>> Gerando gráfico do Paradoxo do Outlier...\")\n","plot_paradoxo_outlier(df)\n","# OBSERVE NO GRÁFICO: As fraudes (Vermelho) estão exatamente onde\n","# o método IQR cortaria os dados globais (lado esquerdo extremo).\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":635},"id":"lF59DBsCqoBG","executionInfo":{"status":"ok","timestamp":1769453899514,"user_tz":180,"elapsed":522,"user":{"displayName":"David Farias","userId":"01485825138402810596"}},"outputId":"3986b0bf-6939-4fe5-f9fd-56b9603f142e"},"execution_count":25,"outputs":[{"output_type":"stream","name":"stdout","text":["\n",">>> Gerando gráfico do Paradoxo do Outlier...\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x600 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# ==============================================================================\n","# 4. DEFININDO OS MÉTODOS DE LIMPEZA (Custom Samplers)\n","# ==============================================================================\n","# Aqui usamos a lógica do 'imblearn.FunctionSampler'.\n","# Essas funções recebem X e y, filtram, e retornam X_novo, y_novo.\n","# ------------------------------------------------------------------------------\n","\n","# --- MÉTODOS A: IQR \"Naive\" (Ingênuo) ---\n","# Remove tudo que foge do padrão da maioria (Legítima).\n","def iqr_outlier_removal(X, y):\n","    original_X = X.copy()\n","    original_y = y.copy()\n","\n","    # Calcula IQR baseado em todo o X recebido no treino\n","    Q1 = X.quantile(0.25)\n","    Q3 = X.quantile(0.75)\n","    IQR = Q3 - Q1\n","\n","    # Define limites\n","    lower_bound = Q1 - 1.5 * IQR\n","    upper_bound = Q3 + 1.5 * IQR\n","\n","    # Filtra: Mantém apenas se TODAS as colunas estiverem dentro dos limites\n","    # (Abordagem conservadora: se for outlier em qualquer coluna, remove)\n","    mask = ~((X < lower_bound) | (X > upper_bound)).any(axis=1)\n","\n","    X_filtered = X[mask]\n","    y_filtered = y[mask]\n","\n","    print(f\" Removeu {len(X) - len(X_filtered)} linhas.\")\n","\n","    # VERIFICAÇÃO E REAJUSTE: Se todas as fraudes foram removidas,\n","    # adiciona-as de volta para evitar erro de classe única no treinamento.\n","    # Isso demonstra o problema do IQR ingênuo em detecção de fraude.\n","    if 1.0 not in np.unique(y_filtered):\n","        print(\" [ATENÇÃO]: IQR removeu TODAS as amostras de fraude. Revertendo para incluir todas as fraudes para que o modelo possa treinar.\")\n","        # Seleciona todas as amostras de fraude originais\n","        fraud_mask_original = (original_y == 1.0)\n","        X_fraud = original_X[fraud_mask_original]\n","        y_fraud = original_y[fraud_mask_original]\n","\n","        # Combina as amostras legítimas filtradas com todas as fraudes originais\n","        legit_mask_filtered = (y_filtered == 0.0)\n","        X_legit_filtered = X_filtered[legit_mask_filtered]\n","        y_legit_filtered = y_filtered[legit_mask_filtered]\n","\n","        X_final = pd.concat([X_legit_filtered, X_fraud], axis=0)\n","        y_final = pd.concat([y_legit_filtered, y_fraud], axis=0)\n","\n","        return X_final, y_final.astype(y.dtype)\n","\n","    return X_filtered, y_filtered\n","\n","# --- MÉTODO B: Isolation Forest (Avançado) ---\n","# Tenta isolar anomalias, mas configurado para focar em ruído, não em sinal.\n","def iso_forest_removal(X, y):\n","    original_X = X.copy()\n","    original_y = y.copy()\n","\n","    # Contamination = 0.01 (assumimos 1% de ruído sujo que queremos limpar)\n","    # Se configurado errado, também pode apagar fraudes!\n","    iso = IsolationForest(contamination=0.01, random_state=42, n_jobs=-1)\n","\n","    # O fit_predict retorna -1 para outlier e 1 para inlier\n","    preds = iso.fit_predict(X)\n","    mask = preds!= -1  # Mantemos apenas os inliers\n","\n","    X_filtered = X[mask]\n","    y_filtered = y[mask]\n","\n","    print(f\"[IsoForest] Removeu {len(X) - len(X_filtered)} linhas.\")\n","\n","    # VERIFICAÇÃO E REAJUSTE: Se todas as fraudes foram removidas,\n","    # adiciona-as de volta para evitar erro de classe única no treinamento.\n","    # Isso demonstra o problema do Isolation Forest se configurado de forma muito agressiva.\n","    if 1.0 not in np.unique(y_filtered):\n","        print(\" [ATENÇÃO]: Isolation Forest removeu TODAS as amostras de fraude. Revertendo para incluir todas as fraudes para que o modelo possa treinar.\")\n","        # Seleciona todas as amostras de fraude originais\n","        fraud_mask_original = (original_y == 1.0)\n","        X_fraud = original_X[fraud_mask_original]\n","        y_fraud = original_y[fraud_mask_original]\n","\n","        # Combina as amostras legítimas filtradas com todas as fraudes originais\n","        legit_mask_filtered = (y_filtered == 0.0)\n","        X_legit_filtered = X_filtered[legit_mask_filtered]\n","        y_legit_filtered = y_filtered[legit_mask_filtered]\n","\n","        X_final = pd.concat([X_legit_filtered, X_fraud], axis=0)\n","        y_final = pd.concat([y_legit_filtered, y_fraud], axis=0)\n","\n","        return X_final, y_final.astype(y.dtype)\n","\n","    return X_filtered, y_filtered\n"],"metadata":{"id":"WTidZgZoqzEp","executionInfo":{"status":"ok","timestamp":1769454276444,"user_tz":180,"elapsed":43,"user":{"displayName":"David Farias","userId":"01485825138402810596"}}},"execution_count":34,"outputs":[]},{"cell_type":"code","source":["# ==============================================================================\n","# 5. CONSTRUÇÃO DOS PIPELINES E TREINAMENTO\n","# ==============================================================================\n","\n","# Pipeline 1: Baseline (Sem tratamento de outlier)\n","pipe_baseline = ImbPipeline([\n","    ('scaler', StandardScaler()),\n","    ('model', LogisticRegression(solver='liblinear', random_state=42, class_weight='balanced'))\n","])\n","\n","# Pipeline 2: Limpeza IQR (A abordagem perigosa)\n","pipe_iqr = ImbPipeline([\n","    ('sampler', FunctionSampler(func=iqr_outlier_removal, validate=False)), # validate=False para permitir que o sampler mude o número de amostras\n","    ('scaler', StandardScaler()),\n","    ('model', LogisticRegression(solver='liblinear', random_state=42, class_weight='balanced'))\n","])\n","\n","# Pipeline 3: Limpeza Isolation Forest (A abordagem cirúrgica)\n","pipe_iso = ImbPipeline([\n","    ('sampler', FunctionSampler(func=iso_forest_removal, validate=False)),\n","    ('scaler', StandardScaler()),\n","    ('model', LogisticRegression(solver='liblinear', random_state=42, class_weight='balanced'))\n","])\n","\n","# Dicionário para iterar\n","pipelines = {\n","    \"Baseline (Sem Limpeza)\": pipe_baseline,\n","    \"IQR (Limpeza Estatística)\": pipe_iqr,\n","    \"Isolation Forest (Limpeza ML)\": pipe_iso\n","}\n","\n","results = {}\n","\n","print(\"\\n>>> Iniciando Treinamento dos Pipelines...\\n\")\n","\n","for name, pipe in pipelines.items():\n","    print(f\"--- Treinando: {name} ---\")\n","    # O fit aqui aplica a remoção APENAS no X_train.\n","    # X_test permanece intacto (com outliers), simulando o mundo real.\n","    pipe.fit(X_train, y_train)\n","\n","    # Previsão de probabilidades para curva PR\n","    y_probs = pipe.predict_proba(X_test)[:, 1]\n","\n","    # Calcular Precision-Recall Curve\n","    precision, recall, _ = precision_recall_curve(y_test, y_probs)\n","    pr_auc = auc(recall, precision)\n","\n","    results[name] = (recall, precision, pr_auc)\n","    print(f\"AUPRC: {pr_auc:.4f}\\n\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"BPlmvjBIq_SE","executionInfo":{"status":"ok","timestamp":1769454284894,"user_tz":180,"elapsed":949,"user":{"displayName":"David Farias","userId":"01485825138402810596"}},"outputId":"a86065a5-c28d-4107-e557-0a317328063a"},"execution_count":35,"outputs":[{"output_type":"stream","name":"stdout","text":["\n",">>> Iniciando Treinamento dos Pipelines...\n","\n","--- Treinando: Baseline (Sem Limpeza) ---\n","AUPRC: 1.0000\n","\n","--- Treinando: IQR (Limpeza Estatística) ---\n"," Removeu 947 linhas.\n"," [ATENÇÃO]: IQR removeu TODAS as amostras de fraude. Revertendo para incluir todas as fraudes para que o modelo possa treinar.\n","AUPRC: 1.0000\n","\n","--- Treinando: Isolation Forest (Limpeza ML) ---\n","[IsoForest] Removeu 400 linhas.\n"," [ATENÇÃO]: Isolation Forest removeu TODAS as amostras de fraude. Revertendo para incluir todas as fraudes para que o modelo possa treinar.\n","AUPRC: 1.0000\n","\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"aaf5a277","executionInfo":{"status":"ok","timestamp":1769454300547,"user_tz":180,"elapsed":948,"user":{"displayName":"David Farias","userId":"01485825138402810596"}},"outputId":"d039b022-bdba-4372-9eed-98667e9a4906"},"source":["# ==============================================================================\n","# 5. CONSTRUÇÃO DOS PIPELINES E TREINAMENTO\n","# ==============================================================================\n","\n","# Pipeline 1: Baseline (Sem tratamento de outlier)\n","pipe_baseline = ImbPipeline([\n","    ('scaler', StandardScaler()),\n","    ('model', LogisticRegression(solver='liblinear', random_state=42, class_weight='balanced'))\n","])\n","\n","# Pipeline 2: Limpeza IQR (A abordagem perigosa)\n","pipe_iqr = ImbPipeline([\n","    ('sampler', FunctionSampler(func=iqr_outlier_removal, validate=False)), # validate=False para permitir que o sampler mude o número de amostras\n","    ('scaler', StandardScaler()),\n","    ('model', LogisticRegression(solver='liblinear', random_state=42, class_weight='balanced'))\n","])\n","\n","# Pipeline 3: Limpeza Isolation Forest (A abordagem cirúrgica)\n","pipe_iso = ImbPipeline([\n","    ('sampler', FunctionSampler(func=iso_forest_removal, validate=False)),\n","    ('scaler', StandardScaler()),\n","    ('model', LogisticRegression(solver='liblinear', random_state=42, class_weight='balanced'))\n","])\n","\n","# Dicionário para iterar\n","pipelines = {\n","    \"Baseline (Sem Limpeza)\": pipe_baseline,\n","    \"IQR (Limpeza Estatística)\": pipe_iqr,\n","    \"Isolation Forest (Limpeza ML)\": pipe_iso\n","}\n","\n","results = {}\n","\n","print(\"\\n>>> Iniciando Treinamento dos Pipelines...\\n\")\n","\n","for name, pipe in pipelines.items():\n","    print(f\"--- Treinando: {name} ---\")\n","    # O fit aqui aplica a remoção APENAS no X_train.\n","    # X_test permanece intacto (com outliers), simulando o mundo real.\n","    pipe.fit(X_train, y_train)\n","\n","    # Previsão de probabilidades para curva PR\n","    y_probs = pipe.predict_proba(X_test)[:, 1]\n","\n","    # Calcular Precision-Recall Curve\n","    precision, recall, _ = precision_recall_curve(y_test, y_probs)\n","    pr_auc = auc(recall, precision)\n","\n","    results[name] = (recall, precision, pr_auc)\n","    print(f\"AUPRC: {pr_auc:.4f}\\n\")\n"],"execution_count":37,"outputs":[{"output_type":"stream","name":"stdout","text":["\n",">>> Iniciando Treinamento dos Pipelines...\n","\n","--- Treinando: Baseline (Sem Limpeza) ---\n","AUPRC: 1.0000\n","\n","--- Treinando: IQR (Limpeza Estatística) ---\n"," Removeu 947 linhas.\n"," [ATENÇÃO]: IQR removeu TODAS as amostras de fraude. Revertendo para incluir todas as fraudes para que o modelo possa treinar.\n","AUPRC: 1.0000\n","\n","--- Treinando: Isolation Forest (Limpeza ML) ---\n","[IsoForest] Removeu 400 linhas.\n"," [ATENÇÃO]: Isolation Forest removeu TODAS as amostras de fraude. Revertendo para incluir todas as fraudes para que o modelo possa treinar.\n","AUPRC: 1.0000\n","\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":744},"id":"c9cbcfd4","executionInfo":{"status":"ok","timestamp":1769454518924,"user_tz":180,"elapsed":120,"user":{"displayName":"David Farias","userId":"01485825138402810596"}},"outputId":"d972e914-a637-4f86-c3fa-f9cd55e56342"},"source":["# ==========================================